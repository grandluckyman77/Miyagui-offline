{
  "name": "miyagui-offline",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "cap:init": "cap init miyagui-offline com.miyagui.app --web-dir dist",
    "cap:add-android": "cap add android",
    "cap:sync": "cap sync",
    "cap:open-android": "cap open android",
    "apk:build": "npm run build && npx cap sync && cd android && ./gradlew assembleDebug"
  },
  "dependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/preferences": "^7.0.0",
    "@capacitor/filesystem": "^7.0.0",
    "@capacitor/device": "^7.0.0",
    "@capacitor/motion": "^7.0.0",
    "@capacitor/geolocation": "^7.0.0",
    "@capacitor/network": "^7.0.0",
    "@capacitor/clipboard": "^7.0.0",
    "@capacitor/toast": "^7.0.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "idb": "^8.0.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-markdown": "^10.1.0",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.3",
    "vite-plugin-pwa": "^0.21.1",
    "workbox-window": "^7.3.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.0",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2"
  }
}